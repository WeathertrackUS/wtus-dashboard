server {
  listen 80;
  server_name dashboard.example.com;

  # Terminate TLS at Nginx in production. Set APP_URL to the public https:// origin.
  # Forward Host and X-Forwarded-Proto from the real listener so the app can build
  # same-origin redirects without trusting client-supplied Host on a direct Node port.

  location / {
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }
}
