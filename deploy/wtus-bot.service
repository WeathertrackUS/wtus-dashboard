[Unit]
Description=WTUS Discord Bot
After=network.target wtus-dashboard.service

[Service]
Type=simple
WorkingDirectory=/opt/wtus-dashboard
EnvironmentFile=/opt/wtus-dashboard/.env
ExecStart=/usr/bin/pnpm bot:start
Restart=always
RestartSec=5
User=wtus
Group=wtus

[Install]
WantedBy=multi-user.target
