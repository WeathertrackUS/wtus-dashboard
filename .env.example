# App
APP_URL=http://127.0.0.1:3000
# Discord OAuth redirect must exactly match: http://127.0.0.1:3000/api/auth/callback/discord
NEXTAUTH_URL=http://127.0.0.1:3000
AUTH_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://wtus:wtus@localhost:5432/wtus_dashboard
# Optional. Set to true only when you explicitly want the old local role preview.
NEXT_PUBLIC_ENABLE_LOCAL_PREVIEW=false

# Discord OAuth / bot verification
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Optional Discord channel defaults
DISCORD_TASK_ALERT_CHANNEL_ID=
DISCORD_AVAILABILITY_ALERT_CHANNEL_ID=
DISCORD_LIVE_EVENT_ALERT_CHANNEL_ID=

# Leantime task backend
LEANTIME_URL=https://tasks.weathertrackus.com
LEANTIME_API_KEY=
LEANTIME_DEFAULT_PROJECT_ID=1

# Discord automated brief delivery. UTC hour defaults to 14 if unset.
DISCORD_BRIEF_HOUR_UTC=14

# Bot sync webhook (instant role sync from dashboard changes)
# Set a shared secret and the bot will expose POST /sync-user on this port.
# The dashboard API calls this after PATCHing member roles/sections.
DISCORD_BOT_SYNC_PORT=3001
DISCORD_BOT_SYNC_SECRET=change-me-to-a-random-secret
