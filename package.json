{
  "name": "wtus-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && next dev --hostname 127.0.0.1",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "admin:grant-role": "tsx scripts/grant-role.ts",
    "admin:revoke-sessions": "tsx scripts/revoke-vulnerable-sessions.ts",
    "build": "prisma generate && next build && node scripts/sync-standalone-assets.mjs",
    "bot:invite": "tsx bot/index.ts --invite-url",
    "bot:register": "tsx bot/index.ts --register-only",
    "bot:start": "tsx bot/index.ts",
    "start": "node .next/standalone/server.js",
    "preview": "next start --hostname 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.544.0",
    "next": "^16.2.5",
    "next-auth": "^4.24.14",
    "openid-client": "^6.8.4",
    "pg": "^8.20.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@types/node": "25.6.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.8"
  }
}
